# Database
DATABASE_URL=postgresql://mealplanner:mealplanner@localhost:5432/mealplanner

# Auth.js
AUTH_SECRET=generate-a-random-secret-at-least-32-chars
APP_URL=http://localhost:3000

# Authentik OIDC (production)
AUTHENTIK_ISSUER=https://auth.example.com/application/o/meal-planner/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Dev only — enables mock login without Authentik (never enable in production)
DEV_AUTH_BYPASS=false

# File uploads
UPLOAD_DIR=./uploads

# USDA FoodData Central for generic ingredient lookup
USDA_API_KEY=
