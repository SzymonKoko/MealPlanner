# Production template for food.rozwinswojbiznes.pl
# Setup once on server:
#   cp .env.production.example .env
#   nano .env   # fill AUTH_SECRET and AUTHENTIK_CLIENT_SECRET
#
# .env is gitignored and persists across git pull / redeploy.

# Used by docker compose variable substitution (${AUTH_SECRET}, etc.)
# DATABASE_URL for app container is set in docker-compose.yml (host: postgres)

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET_32_CHARS
APP_URL=https://food.rozwinswojbiznes.pl

# Authentik OIDC
AUTHENTIK_ISSUER=https://auth.rozwinswojbiznes.pl/application/o/food-planner-app/
AUTHENTIK_CLIENT_ID=yMYFLC66FFQhZ3DXamYO70UeC9A6ozVNGeOwhqtE
AUTHENTIK_CLIENT_SECRET=CHANGE_ME_FROM_AUTHENTIK_PANEL

# Production — always false
DEV_AUTH_BYPASS=false

# Uploads (inside container path is set in docker-compose)
UPLOAD_DIR=./uploads
